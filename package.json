{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@ai-sdk/react": "^3.0.221",
    "@clerk/clerk-expo": "^2.19.31",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@fugood/react-native-audio-pcm-stream": "^1.1.4",
    "@tanstack/react-query": "^5.101.2",
    "ai": "^6.0.219",
    "expo": "~57.0.1",
    "expo-asset": "~57.0.2",
    "expo-audio": "~57.0.0",
    "expo-auth-session": "~57.0.1",
    "expo-constants": "~57.0.2",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.4",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.1",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "env:prod": "node ./scripts/set-env.js prod",
    "env:dev": "node ./scripts/set-env.js dev",
    "env:local": "node ./scripts/set-env.js local",
    "start:prod": "npm run env:prod && expo start --clear",
    "start:dev": "npm run env:dev && expo start --clear",
    "start:local": "npm run env:local && expo start --clear",
    "android:prod": "npm run env:prod && expo run:android",
    "android:dev": "npm run env:dev && expo run:android",
    "android:local": "npm run env:local && expo run:android",
    "ios:prod": "npm run env:prod && expo run:ios",
    "ios:dev": "npm run env:dev && expo run:ios",
    "ios:local": "npm run env:local && expo run:ios"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "@solana-mobile/mobile-wallet-adapter-protocol",
        "@solana-mobile/mobile-wallet-adapter-protocol-web3js"
      ]
    }
  },
  "private": true
}
